    "tracker-wanga"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TrackerWanga/megan-baileys"
  },
  "dependencies": {
    "@cacheable/node-cache": "^1.4.0",
    "@hapi/boom": "^9.1.3",
